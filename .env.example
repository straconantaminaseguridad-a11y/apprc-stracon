# ═══════════════════════════════════════════════
# AppRC — Variables de Entorno
# STRACON · SSOMA · v1.0
#
# Copie este archivo a .env y complete los valores.
# Nunca suba .env al repositorio (está en .gitignore)
# ═══════════════════════════════════════════════

# ─── SERVIDOR ───────────────────────────────────
PORT=3000
JWT_SECRET=cambie_este_valor_a_una_cadena_segura_aleatoria

# ─── BASE DE DATOS ──────────────────────────────
# Ruta al archivo .db de SQLite.
# Si se omite, usa la ruta por defecto: apprc/data/apprc.db
# En servidores con filesystem no-WAL (FUSE, NFS), use /tmp o ruta local:
DB_PATH=/ruta/a/datos/apprc.db

# ─── EMAIL / SMTP ───────────────────────────────
# Configure para activar el envío de constancias y Excel.
# Sin estos valores el sistema guarda logs locales en data/email_log_*.json

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Usuario y contraseña SMTP
# Para Gmail: use una Contraseña de Aplicación (App Password)
# Documentación: https://support.google.com/accounts/answer/185833
SMTP_USER=su.correo@gmail.com
SMTP_PASS=contraseña_de_aplicacion_aqui

# Remitente de los correos enviados
FROM_EMAIL=apprc@stracon.com

# Correo del área SSOMA (recibe el Excel consolidado)
SSOMA_EMAIL=ssoma@stracon.com
